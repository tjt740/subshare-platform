# ============ 第三方登录（OAuth 2.0）============
# 不填 = 演示模式：点按钮直接模拟第三方授权并登录（流程与真实一致，方便本地跑通）
# 填了 = 真实登录：走标准授权码流程
#
# 把本文件复制为 .env 后填写：cp server/.env.example server/.env

# 回调基址：厂商把用户送回后端的地址，必须与厂商控制台登记的完全一致
OAUTH_CALLBACK_BASE=http://localhost:3001
# 前台地址：后端签发 JWT 后把用户送回这里
WEB_ORIGIN=http://localhost:5173

# --- Google ---
# 控制台：https://console.cloud.google.com/apis/credentials
# 授权重定向 URI 填：http://localhost:3001/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub ---
# 控制台：https://github.com/settings/developers → New OAuth App
# Authorization callback URL 填：http://localhost:3001/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Microsoft ---
# 控制台：https://portal.azure.com → Microsoft Entra ID → 应用注册
# 重定向 URI（Web）填：http://localhost:3001/api/auth/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ============ 其他 ============
# JWT 签名密钥（生产环境务必改成随机长串）
JWT_SECRET=change-me-in-production
PORT=3001
